# Dependências
node_modules/

# Build
dist/

# Cache de ferramentas
.vite/
*.tsbuildinfo

# Variáveis de ambiente — nunca commitar segredos
.env
.env.*
*.env

# Dados reais de clientes OmniChat — nunca commitar (testes os usam localmente)
# Exceção: fixtures sintéticas de teste usadas pelos smokes/scripts de debug.
samples/*
!samples/sample01.json
!samples/sample01-v2.json

# Arquivo de workspace pessoal do editor
*.code-workspace

# Logos/artes soltas na raiz (não referenciadas no app)
/Omnichat Logo*.png
/Omnichat-Logo*.svg

# Editor / SO
.vscode/
.idea/
Thumbs.db
.DS_Store

# Config local do Claude Code (permissões específicas da máquina)
.claude/settings.local.json

# Backups de sessão da camada de tools do agente (FlowStore.beginMutation → <arquivo>.bak)
*.bak

# Logs
*.log
npm-debug.log*
